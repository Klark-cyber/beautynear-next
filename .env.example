# ─── LOKAL RIVOJLANTIRISH (local dev) ────────────────────────────────────
# Agar backend shu kompyuterda ishlasa:
# REACT_APP_API_URL=http://localhost:3010
# REACT_APP_API_GRAPHQL_URL=http://localhost:3010/graphql
# REACT_APP_API_WS=ws://localhost:3010

# ─── PRODUCTION (deploy qilingandan keyin) ────────────────────────────────
# ⚠️ Backend qayerga deploy qilinsa (Render, Railway, VPS va h.k.),
# quyidagi 3 qatorni O'SHA haqiqiy manzil bilan almashtiring. Vercel kabi
# platformalarda buni kodda emas, loyihaning "Environment Variables"
# sozlamalaridan qo'shish tavsiya etiladi (xavfsizroq va har muhit uchun
# alohida qiymat berish imkonini beradi).
REACT_APP_API_URL=https://<your-backend-domain>
REACT_APP_API_GRAPHQL_URL=https://<your-backend-domain>/graphql
REACT_APP_API_WS=wss://<your-backend-domain>
